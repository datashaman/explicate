{
    "mcpServers": {
        "laravel-boost": {
            "command": "php",
            "args": [
                "artisan",
                "boost:mcp"
            ]
        },
        "explicate-local": {
            "command": "php",
            "args": [
                "artisan",
                "mcp:start",
                "explicate"
            ]
        }
    }
}
