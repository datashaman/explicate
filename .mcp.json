{
    "mcpServers": {
        "laravel-boost": {
            "command": "php",
            "args": [
                "artisan",
                "boost:mcp"
            ]
        },
        "topic-forge-local": {
            "command": "php",
            "args": [
                "artisan",
                "mcp:start",
                "topic-forge"
            ]
        }
    }
}
